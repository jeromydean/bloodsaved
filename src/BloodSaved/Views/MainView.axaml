<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:viewModels="using:BloodSaved.ViewModels"
  xmlns:models="using:BloodSaved.Models"
  xmlns:converters="using:BloodSaved.Converters"
  xmlns:skControls="using:Avalonia.Controls.Skia"
  xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Xaml.Behaviors.Interactivity"
  xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Xaml.Behaviors.Interactions"
  xmlns:s="clr-namespace:System;assembly=mscorlib"
  mc:Ignorable="d"
  d:DesignWidth="800"
  d:DesignHeight="450"
  x:Class="BloodSaved.Views.MainView"
  x:DataType="viewModels:MainViewModel"
  Icon="/Assets/icon.ico"
  Title="BloodSaved">
  <Window.Resources>
    <converters:StringIsNotNullOrEmptyToBooleanConverter
      x:Key="StringIsNotNullOrEmptyToBooleanConverter" />
    <s:Boolean x:Key="FalseValue">False</s:Boolean>
    <s:Boolean x:Key="TrueValue">True</s:Boolean>
  </Window.Resources>
  <i:Interaction.Behaviors>
    <ia:EventTriggerBehavior
      EventName="Opened">
      <ia:InvokeCommandAction
        Command="{Binding OpenedCommand, Mode=OneTime}" />
    </ia:EventTriggerBehavior>
  </i:Interaction.Behaviors>
  <!--<Design.DataContext>
    <viewModels:MainViewModel />
  </Design.DataContext>-->
  <DockPanel>
    <DockPanel.Background>
      <ImageBrush
        Stretch="None"
        Source="/Assets/background.png" />
    </DockPanel.Background>
    <Menu
      DockPanel.Dock="Top">
      <MenuItem
        Header="_File">
        <MenuItem
          Header="_Open"
          Command="{Binding OpenCommand}" />
        <MenuItem
          Header="_Close"
          IsEnabled="{Binding IsSaveSlotLoaded}"
          Command="{Binding CloseCommand}" />
        <MenuItem
          Header="_Save"
          IsEnabled="{Binding IsSaveSlotLoaded}"
          Command="{Binding SaveCommand}" />
        <Separator />
        <MenuItem
          Header="Save _As"
          IsEnabled="{Binding IsSaveSlotLoaded}">
          <MenuItem.Items>
            <MenuItem
              Header="Save _Encrypted Version"
              Command="{Binding SaveAsCommand}"
              CommandParameter="{StaticResource TrueValue}" />
            <MenuItem
              Header="Save _Decrypted Version"
              Command="{Binding SaveAsCommand}"
              CommandParameter="{StaticResource FalseValue}" />
          </MenuItem.Items>
        </MenuItem>
        <Separator />
        <MenuItem
          Header="_Exit"
          Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem
        Header="_About"
        Command="{Binding AboutCommand}" />
    </Menu>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TabControl
        Grid.Row="0"
        IsVisible="{Binding IsSaveSlotLoaded}"
        Margin="5">
        <TabControl.Styles>
          <Style
            Selector="Grid.TabPage">
            <Setter Property="Background">
              <SolidColorBrush Color="Black" Opacity=".75" />
            </Setter>
          </Style>
        </TabControl.Styles>
        <TabItem
          Header="Stats">
          <Grid
            Classes="TabPage">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Label
              Grid.Row="0"
              Grid.Column="0"
              VerticalContentAlignment="Center"
              Content="Total Coins:" />
            <NumericUpDown
              Grid.Row="0"
              Grid.Column="1"
              Margin="5"
              Value="{Binding TotalCoins}"
              FormatString="N0"
              Minimum="0"
              Maximum="999999999"
              HorizontalAlignment="Stretch" />

            <Label
              Grid.Row="1"
              Grid.Column="0"
              VerticalContentAlignment="Center"
              Content="Total Experience:" />
            <NumericUpDown
              Grid.Row="1"
              Grid.Column="1"
              Margin="5"
              Value="{Binding TotalExperience}"
              FormatString="N0"
              Minimum="0"
              Maximum="999999999"
              HorizontalAlignment="Stretch" />

            <Label
              Grid.Row="2"
              Grid.Column="0"
              VerticalContentAlignment="Center"
              Content="Difficulty:" />
            <ComboBox
              Grid.Row="2"
              Grid.Column="1"
              Margin="5"
              ItemsSource="{Binding EPBGameLevels}"
              SelectedItem="{Binding EPBGameLevel}" />

            <ScrollViewer
              Grid.Row="3"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              Margin="5,15,5,5"
              IsVisible="{Binding HasGameRecord}"
              VerticalScrollBarVisibility="Auto"
              MaxHeight="320">
              <StackPanel Spacing="5">
                <TextBlock
                  FontWeight="Bold"
                  Text="Game Record" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                  <Label Grid.Row="0" Grid.Column="0" VerticalContentAlignment="Center" Content="Total Kill Count:" />
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalKillCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="1" Grid.Column="0" VerticalContentAlignment="Center" Content="Total Room Entries:" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalRoomInCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="2" Grid.Column="0" VerticalContentAlignment="Center" Content="Total Sales Gold:" />
                  <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalSalesGold}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="3" Grid.Column="0" VerticalContentAlignment="Center" Content="Quests Cleared:" />
                  <NumericUpDown Grid.Row="3" Grid.Column="1" Margin="5,0,0,0" Value="{Binding QuestClearCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="4" Grid.Column="0" VerticalContentAlignment="Center" Content="Alchemy Crafts:" />
                  <NumericUpDown Grid.Row="4" Grid.Column="1" Margin="5,0,0,0" Value="{Binding AlchemyCraftCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="5" Grid.Column="0" VerticalContentAlignment="Center" Content="Treasure Boxes Opened:" />
                  <NumericUpDown Grid.Row="5" Grid.Column="1" Margin="5,0,0,0" Value="{Binding OpenTreasureBoxCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="6" Grid.Column="0" VerticalContentAlignment="Center" Content="Candles Destroyed:" />
                  <NumericUpDown Grid.Row="6" Grid.Column="1" Margin="5,0,0,0" Value="{Binding DestroyedCandleCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="7" Grid.Column="0" VerticalContentAlignment="Center" Content="Walls Broken:" />
                  <NumericUpDown Grid.Row="7" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalBrokenWall}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="8" Grid.Column="0" VerticalContentAlignment="Center" Content="OD Chair Actions:" />
                  <NumericUpDown Grid.Row="8" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalOdChairAction}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="9" Grid.Column="0" VerticalContentAlignment="Center" Content="Books Borrowed:" />
                  <NumericUpDown Grid.Row="9" Grid.Column="1" Margin="5,0,0,0" Value="{Binding BorrowBooksCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="10" Grid.Column="0" VerticalContentAlignment="Center" Content="Dish Types Cooked:" />
                  <NumericUpDown Grid.Row="10" Grid.Column="1" Margin="5,0,0,0" Value="{Binding CookedDishesType}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="11" Grid.Column="0" VerticalContentAlignment="Center" Content="Unique Familiars Summoned:" />
                  <NumericUpDown Grid.Row="11" Grid.Column="1" Margin="5,0,0,0" Value="{Binding UniqueFamiliarsSummonedCount}" FormatString="N0" Minimum="0" Maximum="11" />
                </Grid>
                <TextBlock
                  Margin="0,8,0,0"
                  FontWeight="Bold"
                  Text="PC Record" />
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                  <Label Grid.Row="0" Grid.Column="0" VerticalContentAlignment="Center" Content="Longest Jump Kick Streak:" />
                  <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" Value="{Binding ContinuousJumpKickCount}" FormatString="N0" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="1" Grid.Column="0" VerticalContentAlignment="Center" Content="Total Move Distance:" />
                  <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalMoveDistance}" FormatString="N2" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="2" Grid.Column="0" VerticalContentAlignment="Center" Content="Total Back Step Distance:" />
                  <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="5,0,0,0" Value="{Binding TotalBackStepMoveDistance}" FormatString="N2" Minimum="0" Maximum="999999999" />
                  <Label Grid.Row="3" Grid.Column="0" VerticalContentAlignment="Center" Content="Blood Stele Amount:" />
                  <NumericUpDown Grid.Row="3" Grid.Column="1" Margin="5,0,0,0" Value="{Binding BloodSteeleAmount}" FormatString="N2" Minimum="0" Maximum="999999999" />
                </Grid>
              </StackPanel>
            </ScrollViewer>

            <DataGrid
              x:Name="FamiliarExperienceGrid"
              Grid.Row="4"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              Margin="5,15,5,5"
              ItemsSource="{Binding FamiliarExperience}">
              <DataGrid.Columns>
                <DataGridTextColumn
                  Header="Familiar Name"
                  Binding="{Binding Name}"
                  IsReadOnly="true"
                  Width="Auto" />
                <DataGridTextColumn
                  Header="Description"
                  Binding="{Binding Description}"
                  IsReadOnly="true"
                  Width="*" />
                <DataGridTemplateColumn
                  SortMemberPath="Experience"
                  Header="Experience"
                  Width="125">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate
                      DataType="models:FamiliarExperienceModel">
                      <TextBlock
                        Text="{Binding Experience}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                  <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate
                      DataType="models:FamiliarExperienceModel">
                      <NumericUpDown
                        Value="{Binding Experience}"
                        FormatString="N0"
                        Minimum="0"
                        Maximum="999999999"
                        HorizontalAlignment="Stretch" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

          </Grid>
        </TabItem>
        <TabItem
          Header="Inventory">
          <Grid
            Classes="TabPage">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
              Grid.Row="0"
              Margin="5"
              HorizontalAlignment="Center">
              <Run
                Text="Tips:"
                FontWeight="Bold" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Ctrl+A to select all" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Hold shift while clicking to select specific" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Right click to quickly set quantity of selected items" />
            </TextBlock>
            <DataGrid
              x:Name="ItemsDataGrid"
              Grid.Row="1"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="All"
              BorderThickness="1"
              BorderBrush="Gray"
              ItemsSource="{Binding InventoryItems}">
              <i:Interaction.Behaviors>
                <ia:EventTriggerBehavior
                  EventName="SelectionChanged">
                  <ia:InvokeCommandAction
                    Command="{Binding ItemSelectionChangedCommand}"
                    CommandParameter="{Binding ElementName=ItemsDataGrid, Path=SelectedItems }" />
                </ia:EventTriggerBehavior>
              </i:Interaction.Behaviors>
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem
                    Header="Set Quantity"
                    IsEnabled="{Binding ItemsSelected}">
                    <MenuItem
                      Header="9"
                      Command="{Binding SetSelectedItemQuantityCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>9</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                    <MenuItem
                      Header="999"
                      Command="{Binding SetSelectedItemQuantityCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>999</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                    <MenuItem
                      Header="9999"
                      Command="{Binding SetSelectedItemQuantityCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>9999</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                  </MenuItem>
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTextColumn
                  Header="Category"
                  Binding="{Binding Category}"
                  IsReadOnly="true"
                  Width="Auto" />
                <DataGridTextColumn
                  Header="Name"
                  Binding="{Binding Name}"
                  IsReadOnly="true"
                  Width="Auto" />
                <DataGridTextColumn
                  Header="Description"
                  Binding="{Binding Description}"
                  IsReadOnly="true"
                  Width="*" />
                <DataGridTemplateColumn
                  SortMemberPath="Quantity"
                  Header="Quantity"
                  Width="125">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate
                      DataType="models:InventoryItemModel">
                      <TextBlock
                        Text="{Binding Quantity}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                  <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate
                      DataType="models:InventoryItemModel">
                      <NumericUpDown
                        Value="{Binding Quantity}"
                        FormatString="N0"
                        Minimum="0"
                        Maximum="9999"
                        HorizontalAlignment="Stretch" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>
        <TabItem
          Header="Shards">
          <Grid
            Classes="TabPage">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
              Grid.Row="0"
              Margin="5"
              HorizontalAlignment="Center">
              <Run
                Text="Tips:"
                FontWeight="Bold" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Ctrl+A to select all" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Hold shift while clicking to select specific" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Right click to quickly set grade/rank of selected shards" />
            </TextBlock>
            <DataGrid
              x:Name="ShardsDataGrid"
              Grid.Row="1"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="All"
              BorderThickness="1"
              BorderBrush="Gray"
              ItemsSource="{Binding Shards}">
              <i:Interaction.Behaviors>
                <ia:EventTriggerBehavior
                  EventName="SelectionChanged">
                  <ia:InvokeCommandAction
                    Command="{Binding ShardSelectionChangedCommand}"
                    CommandParameter="{Binding ElementName=ShardsDataGrid, Path=SelectedItems }" />
                </ia:EventTriggerBehavior>
              </i:Interaction.Behaviors>
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem
                    Header="Set Grade"
                    IsEnabled="{Binding ShardsSelected}">
                    <MenuItem
                      Header="9"
                      Command="{Binding SetSelectedShardGradeCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>9</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                    <MenuItem
                      Header="999"
                      Command="{Binding SetSelectedShardGradeCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>999</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                    <MenuItem
                      Header="9999"
                      Command="{Binding SetSelectedShardGradeCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>9999</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                  </MenuItem>
                  <MenuItem
                    Header="Set Rank"
                    IsEnabled="{Binding ShardsSelected}">
                    <MenuItem
                      Header="9"
                      Command="{Binding SetSelectedShardRankCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>9</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                    <MenuItem
                      Header="999"
                      Command="{Binding SetSelectedShardRankCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>999</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                    <MenuItem
                      Header="9999"
                      Command="{Binding SetSelectedShardRankCommand}">
                      <MenuItem.CommandParameter>
                        <s:Int32>9999</s:Int32>
                      </MenuItem.CommandParameter>
                    </MenuItem>
                  </MenuItem>
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTextColumn
                  Header="Category"
                  Binding="{Binding Category}"
                  IsReadOnly="true"
                  Width="Auto" />
                <DataGridTextColumn
                  Header="Name"
                  Binding="{Binding Name}"
                  IsReadOnly="true"
                  Width="Auto" />
                <DataGridTextColumn
                  Header="Description"
                  Binding="{Binding Description}"
                  IsReadOnly="true"
                  Width="*" />
                <DataGridTemplateColumn
                  SortMemberPath="Quantity"
                  Header="Grade"
                  Width="125">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate
                      DataType="models:InventoryItemModel">
                      <TextBlock
                        Text="{Binding Quantity}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                  <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate
                      DataType="models:InventoryItemModel">
                      <NumericUpDown
                        Value="{Binding Quantity}"
                        FormatString="N0"
                        Minimum="0"
                        Maximum="9999"
                        HorizontalAlignment="Stretch" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn
                  SortMemberPath="Rank"
                  Header="Rank"
                  Width="125">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate
                      DataType="models:InventoryItemModel">
                      <TextBlock
                        Text="{Binding Rank}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                  <DataGridTemplateColumn.CellEditingTemplate>
                    <DataTemplate DataType="models:InventoryItemModel">
                      <NumericUpDown
                        Value="{Binding Rank}"
                        FormatString="N0"
                        Minimum="0"
                        Maximum="9999"
                        HorizontalAlignment="Stretch" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>
        <TabItem
          Header="Techniques"
          IsVisible="{Binding HasGameRecord}">
          <Grid
            Classes="TabPage">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
              Grid.Row="0"
              Margin="5"
              HorizontalAlignment="Center">
              <Run
                Text="Tips:"
                FontWeight="Bold" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Ctrl+A to select all" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Right click to master selected techniques" />
            </TextBlock>
            <DataGrid
              x:Name="TechniquesDataGrid"
              Grid.Row="1"
              ItemsSource="{Binding Techniques}"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="All"
              BorderThickness="1"
              BorderBrush="Gray"
              Margin="5">
              <i:Interaction.Behaviors>
                <ia:EventTriggerBehavior
                  EventName="SelectionChanged">
                  <ia:InvokeCommandAction
                    Command="{Binding TechniqueSelectionChangedCommand}"
                    CommandParameter="{Binding ElementName=TechniquesDataGrid, Path=SelectedItems}" />
                </ia:EventTriggerBehavior>
              </i:Interaction.Behaviors>
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem
                    Header="Master Selected"
                    IsEnabled="{Binding TechniquesSelected}"
                    Command="{Binding MasterSelectedTechniquesCommand}" />
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTextColumn
                  Header="Technique"
                  Binding="{Binding Name}"
                  IsReadOnly="true"
                  Width="Auto" />
                <DataGridTextColumn
                  Header="ID"
                  Binding="{Binding ArtsIdKey}"
                  IsReadOnly="true"
                  Width="80" />
                <DataGridTemplateColumn
                  SortMemberPath="IsMastered"
                  Header="Mastered"
                  Width="100"
                  IsReadOnly="False">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="models:TechniqueModel">
                      <CheckBox
                        IsChecked="{Binding IsMastered, Mode=TwoWay}"
                        IsEnabled="{Binding HasMastery}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>
        <TabItem
          Header="Quests"
          IsVisible="{Binding HasGameRecord}">
          <Grid
            Classes="TabPage">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
              Grid.Row="0"
              Margin="5"
              HorizontalAlignment="Center">
              <Run
                Text="Tips:"
                FontWeight="Bold" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Ctrl+A to select all" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Right click to complete selected quests" />
            </TextBlock>
            <DataGrid
              x:Name="QuestsDataGrid"
              Grid.Row="1"
              ItemsSource="{Binding Quests}"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              CanUserSortColumns="True"
              GridLinesVisibility="All"
              BorderThickness="1"
              BorderBrush="Gray"
              Margin="5">
              <i:Interaction.Behaviors>
                <ia:EventTriggerBehavior
                  EventName="SelectionChanged">
                  <ia:InvokeCommandAction
                    Command="{Binding QuestSelectionChangedCommand}"
                    CommandParameter="{Binding ElementName=QuestsDataGrid, Path=SelectedItems}" />
                </ia:EventTriggerBehavior>
              </i:Interaction.Behaviors>
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem
                    Header="Complete Selected"
                    IsEnabled="{Binding QuestsSelected}"
                    Command="{Binding CompleteSelectedQuestsCommand}" />
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTextColumn
                  Header="Category"
                  Binding="{Binding Category}"
                  IsReadOnly="true"
                  Width="120" />
                <DataGridTextColumn
                  Header="Quest"
                  Binding="{Binding Name}"
                  IsReadOnly="true"
                  Width="*" />
                <DataGridTextColumn
                  Header="ID"
                  Binding="{Binding QuestId}"
                  IsReadOnly="true"
                  Width="160" />
                <DataGridTemplateColumn
                  SortMemberPath="IsCompleted"
                  Header="Completed"
                  Width="120"
                  IsReadOnly="False">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate DataType="models:QuestModel">
                      <CheckBox
                        IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>
        <TabItem
          Header="Map">
          <Grid
            Classes="TabPage">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel
              Grid.Row="0"
              Margin="5"
              Orientation="Horizontal"
              HorizontalAlignment="Center"
              Spacing="10">
              <Button
                Content="Set Map 100% Discovered"
                Command="{Binding CompleteMapCommand}" />
              <TextBlock VerticalAlignment="Center" Text="Map progress:" />
              <TextBlock VerticalAlignment="Center" Text="{Binding MapTraversedRoomCount}" />
              <TextBlock VerticalAlignment="Center" Text="/" />
              <TextBlock VerticalAlignment="Center" Text="{Binding MapTotalRoomCount}" />
            </StackPanel>
            <TextBlock
              Grid.Row="1"
              Margin="5"
              HorizontalAlignment="Center">
              <Run
                Text="Tips:"
                FontWeight="Bold" />
              <LineBreak />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Hold CTRL while using the mouse wheel to control zoom level" />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Click and drag to pan the map" />
              <Run
                Text="    •"
                FontWeight="Bold" />
              <Run
                Text="Right click to save the map as an SVG file" />
              <LineBreak />
            </TextBlock>
            <ScrollViewer
              x:Name="mapScrollViewer"
              Grid.Row="2"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              AllowAutoHide="True">
              <LayoutTransformControl
                x:Name="mapLayoutRoot"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <LayoutTransformControl.LayoutTransform>
                  <ScaleTransform
                    ScaleX="{Binding MapScale}"
                    ScaleY="{Binding MapScale}" />
                </LayoutTransformControl.LayoutTransform>
                <skControls:SKPictureControl
                  x:Name="mapControl"
                  HorizontalAlignment="Center"
                  Cursor="Hand"
                  Picture="{Binding Map}"
                  Width="{Binding ElementName=mapScrollViewer, Path=Viewport.Width}"
                  PointerWheelChanged="MapPointerWheelChanged"
                  PointerPressed="MapPointerPressed"
                  PointerMoved="MapPointerMoved"
                  PointerReleased="MapPointerReleased"
                  PointerCaptureLost="MapPointerCaptureLost">
                  <skControls:SKPictureControl.ContextMenu>
                    <ContextMenu>
                      <MenuItem
                        Header="Save As"
                        Command="{Binding SaveMapAsCommand}"
                        CommandParameter="{Binding ElementName=mapControl, Path=Picture}" />
                    </ContextMenu>
                  </skControls:SKPictureControl.ContextMenu>
                </skControls:SKPictureControl>
              </LayoutTransformControl>
            </ScrollViewer>
          </Grid>
        </TabItem>
      </TabControl>
      <SelectableTextBlock
        Grid.Row="1"
        Padding="0,0,0,25"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Text="{Binding LoadErrorText}"
        FontSize="15"
        TextWrapping="Wrap"
        IsVisible="{Binding LoadErrorText, Converter={StaticResource StringIsNotNullOrEmptyToBooleanConverter}}" />
    </Grid>
  </DockPanel>
</Window>